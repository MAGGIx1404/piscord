# PostgreSQL (Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=piscord

# Database connection (Kysely / pg)
DB_NAME=piscord
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=
DB_PORT=5432
DB_MAX_POOL_SIZE=10

# JWT
JWT_SECRET=
